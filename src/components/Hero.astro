---
import { resumeData } from '../data/resume';
---

<section class="max-w-6xl mx-auto px-6 py-12 md:py-24" id="about">
  <!-- Terminal Window -->
  <div class="border relative overflow-hidden" style="background-color: var(--color-surface-container-lowest); border-color: rgba(65, 71, 84, 0.2)">
    <!-- Terminal Header - macOS buttons -->
    <div class="px-4 py-3 flex items-center gap-2" style="background-color: var(--color-surface-container-low)">
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full" style="background-color: #ff5f57; box-shadow: 0 0 4px rgba(255,95,87,0.4)"></span>
        <span class="w-3 h-3 rounded-full" style="background-color: #febc2e; box-shadow: 0 0 4px rgba(254,188,46,0.4)"></span>
        <span class="w-3 h-3 rounded-full" style="background-color: #28c840; box-shadow: 0 0 4px rgba(40,200,64,0.4)"></span>
      </div>
      <span class="text-[10px] font-mono ml-4" style="color: var(--color-on-surface-variant); opacity: 0.5">bash — architect@dvlad-system</span>
    </div>

    <!-- Terminal Content - below header -->
    <div class="p-4 sm:p-6 md:p-10 lg:p-12 relative">
      <div class="mb-4 sm:mb-6">
        <span class="font-mono mr-2 text-xs sm:text-sm" style="color: var(--color-primary)">&gt;</span>
        <span class="text-xs sm:text-sm font-mono" style="color: var(--color-on-surface-variant)">init --profile "{resumeData.name}"</span>
      </div>

      <h1 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-bold headline-font leading-tight tracking-tighter mb-3 sm:mb-4">
        I Help Engineering Teams Ship on Azure
      </h1>
      <p class="text-xl sm:text-2xl md:text-3xl font-light mb-6 sm:mb-8" style="color: var(--color-primary)">
        Without Rebuilding Their Stack.
      </p>

      <p class="text-base sm:text-lg md:text-2xl max-w-3xl mb-6 sm:mb-8 font-light leading-relaxed" style="color: var(--color-secondary)">
        Former Microsoft engineer now helping companies <span class="font-bold" style="color: var(--color-primary)">ship faster, spend less, and sleep better</span> — with infrastructure that actually works.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 md:gap-8 pt-4 sm:pt-6" style="border-top: 1px solid rgba(65, 71, 84, 0.1)">
        <div>
          <div class="text-[10px] sm:text-xs font-mono uppercase tracking-widest mb-1 sm:mb-2" style="color: var(--color-primary)">STATUS</div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background-color: var(--color-primary); animation: pulse 2s infinite;"></span>
            <span class="text-xs sm:text-sm" style="color: var(--color-on-surface)">Available for projects</span>
          </div>
        </div>
        <div>
          <div class="text-[10px] sm:text-xs font-mono uppercase tracking-widest mb-1 sm:mb-2" style="color: var(--color-secondary)">CORE_STACK</div>
          <div class="text-xs sm:text-sm" style="color: var(--color-on-surface)">Azure, Kubernetes, Terraform, CI/CD</div>
        </div>
        <div>
          <div class="text-[10px] sm:text-xs font-mono uppercase tracking-widest mb-1 sm:mb-2" style="color: var(--color-on-surface-variant)">LOCATION</div>
          <div class="text-xs sm:text-sm" style="color: var(--color-on-surface)">Munich // Remote — Global Node</div>
        </div>
      </div>

      <style>
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.4; }
        }
      </style>

      <!-- Visual Bleed Background (Terraform code) -->
      <div class="absolute -right-20 -bottom-20 opacity-5 pointer-events-none hidden lg:block">
        <div class="text-[8px] font-mono leading-none" style="color: var(--color-primary)">
          <pre>resource "azurerm_kubernetes_cluster" "prod" &#123;
    name                = "dvlad-architect-cluster"
    location            = "West Europe"
    dns_prefix          = "dvlad-prod"
    default_node_pool &#123;
        name       = "default"
        node_count = 3
        vm_size    = "Standard_D2_v2"
    &#125;
    identity &#123;
        type = "SystemAssigned"
    &#125;
&#125;</pre>
        </div>
      </div>
    </div>
  </div>
</section>
