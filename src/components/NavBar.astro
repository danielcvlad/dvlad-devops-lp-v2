---
const linkedinUrl = "https://linkedin.com/in/dancvlad";
const gitlabUrl = "https://gitlab.com/danielcvlad";
const githubUrl = "https://github.com/danielcvlad";
const resumeUrl = "/dvlad-devops-lp/CV_Daniel_Vlad.pdf";
---

<!-- Floating theme toggle — mobile only, centered right -->
<button
  id="theme-toggle-float"
  onclick="toggleTheme()"
  class="fixed right-4 bottom-6 z-50 flex items-center justify-center w-12 h-12 rounded-full shadow-lg md:hidden"
  style="background-color: var(--color-surface-container-high); color: var(--color-on-surface-variant)"
  title="Toggle dark/light mode"
  aria-label="Toggle theme"
>
  <svg id="theme-toggle-float-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
</button>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 hidden" style="background-color: rgba(0,0,0,0.5)">
  <div id="mobile-menu-drawer" class="absolute left-0 top-0 bottom-0 w-72 max-w-[80vw] transform -translate-x-full transition-transform duration-300" style="background-color: var(--color-background)">
    <div class="p-4 border-b" style="border-color: rgba(65, 71, 84, 0.3)">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-lg font-black" style="color: var(--color-primary)">{'>'}</span>
          <span class="font-bold headline-font">Menu</span>
        </div>
        <button onclick="toggleMobileMenu()" class="p-2" aria-label="Close menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    <nav class="p-4 space-y-2">
      <a onclick="toggleMobileMenu()" href="#about" class="block py-3 px-4 headline-font text-sm tracking-widest uppercase rounded" style="color: var(--color-secondary)">About</a>
      <a onclick="toggleMobileMenu()" href="#experience" class="block py-3 px-4 headline-font text-sm tracking-widest uppercase rounded" style="color: var(--color-secondary)">Experience</a>
      <a onclick="toggleMobileMenu()" href="#projects" class="block py-3 px-4 headline-font text-sm tracking-widest uppercase rounded" style="color: var(--color-secondary)">Projects</a>
      <a onclick="toggleMobileMenu()" href="#contact" class="block py-3 px-4 headline-font text-sm tracking-widest uppercase rounded" style="color: var(--color-secondary)">Contact</a>
    </nav>
    <div class="p-4 border-t space-y-3" style="border-color: rgba(65, 71, 84, 0.3)">
      <a href={resumeUrl} download class="flex items-center justify-center gap-2 w-full py-3 px-4 font-mono text-xs uppercase tracking-widest rounded border transition-colors hover:opacity-80" style="border-color: var(--color-outline-variant); color: var(--color-secondary)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Resume
      </a>
      <a href="#contact" onclick="toggleMobileMenu()" class="flex items-center justify-center w-full py-3 px-4 font-mono text-xs uppercase tracking-widest rounded transition-colors hover:opacity-80" style="background-color: var(--color-primary); color: var(--color-background)">
        HIRE_ME
      </a>
    </div>
  </div>
</div>

<script is:inline>
  function toggleMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const drawer = document.getElementById('mobile-menu-drawer');
    menu.classList.toggle('hidden');
    drawer.classList.toggle('-translate-x-full');
  }
  
  // Close menu when clicking overlay
  document.getElementById('mobile-menu').addEventListener('click', function(e) {
    if (e.target === this) {
      toggleMobileMenu();
    }
  });
</script>

<header class="fixed top-0 left-0 right-0 z-50 border-b-0" style="background-color: var(--color-background)">
  <div class="flex justify-between items-center w-full px-4 md:px-6 py-3 max-w-[1920px] mx-auto relative">
    <!-- Mobile: hamburger + logo, Desktop: logo + nav + buttons -->
    <div class="flex items-center gap-4 w-full justify-between">
      <!-- Hamburger — mobile only -->
      <button onclick="toggleMobileMenu()" class="flex md:hidden items-center justify-center w-10 h-10" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>

      <!-- Logo -->
      <div class="w-8 h-8 flex items-center justify-center">
        <span class="text-lg font-black" style="color: var(--color-primary)">{'>'}</span>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a class="pb-1 headline-font text-sm tracking-widest uppercase nav-link" style="color: var(--color-primary); border-bottom: 1px solid var(--color-primary)" href="#about">About</a>
        <a class="headline-font text-sm tracking-widest uppercase nav-link" style="color: var(--color-secondary); opacity: 0.7" href="#experience">Experience</a>
        <a class="headline-font text-sm tracking-widest uppercase nav-link" style="color: var(--color-secondary); opacity: 0.7" href="#projects">Projects</a>
        <a class="headline-font text-sm tracking-widest uppercase nav-link" style="color: var(--color-secondary); opacity: 0.7" href="#contact">Contact</a>
      </nav>

      <!-- Spacer for mobile logo centering -->
      <div class="w-10 md:hidden"></div>

      <!-- Buttons -->
      <div class="flex items-center gap-2 md:gap-4">
        <!-- Theme Toggle — desktop only, hidden on mobile -->
        <button
          id="theme-toggle"
          onclick="toggleTheme()"
          class="hidden md:flex items-center justify-center w-10 h-10 transition-opacity hover:opacity-70"
          style="color: var(--color-on-surface-variant)"
          title="Toggle dark/light mode"
          aria-label="Toggle theme"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href={gitlabUrl} target="_blank" class="flex items-center justify-center w-10 h-10 icon-gitlab" title="GitLab">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>
        </a>
        <a href={githubUrl} target="_blank" class="flex items-center justify-center w-10 h-10 icon-github" title="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <a href={linkedinUrl} target="_blank" class="flex items-center justify-center w-10 h-10 icon-linkedin" title="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={resumeUrl} download class="btn-secondary hidden sm:inline-flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          Resume
        </a>
        <a href="#contact" class="btn-primary">
          HIRE_ME
        </a>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full h-[1px]" style="background: linear-gradient(to right, var(--color-primary), transparent, transparent)"></div>
  </div>
</header>
