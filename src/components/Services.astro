---
---

<section class="py-24 border-t" style="background-color: var(--color-background); border-color: rgba(65, 71, 84, 0.1)" id="services">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold headline-font tracking-tighter uppercase mb-4">What I Do</h2>
      <p class="max-w-2xl mx-auto" style="color: var(--color-on-surface-variant)">
        From bottleneck to deployment — I help engineering teams ship faster without sacrificing security or stability.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- CI/CD Optimization -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(52, 229, 7, 0.1)">
          <span class="material-symbols-outlined text-2xl text-primary">rocket_launch</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-primary)">CI/CD Pipeline Optimization</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)">
          Cut deployment time from hours to minutes. Automated testing, parallel jobs, and zero-downtime releases.
        </p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)">
          Jenkins · GitHub Actions · Azure DevOps
        </div>
      </div>

      <!-- Infrastructure Migration -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(171, 199, 255, 0.1)">
          <span class="material-symbols-outlined text-2xl text-secondary">cloud_sync</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-secondary)">Cloud Infrastructure Migration</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)">
          Move from on-prem to cloud-native. Azure, AWS, GCP — designed for scale, built for cost efficiency.
        </p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)">
          Terraform · Bicep · ARM Templates
        </div>
      </div>

      <!-- Security Hardening -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(52, 229, 7, 0.1)">
          <span class="material-symbols-outlined text-2xl text-primary">security</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-primary)">Security & Compliance</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)">
          Vault, zero-trust networks, policy-as-code. Pass audits without slowing down your team.
        </p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)">
          HashiCorp Vault · Azure Policy · Sentinel
        </div>
      </div>

      <!-- DevOps Audit -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(171, 199, 255, 0.1)">
          <span class="material-symbols-outlined text-2xl text-secondary">manage_search</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-secondary)">Infrastructure Audit</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)">
          30-minute free review of your deployment pipeline. You'll leave with 3 actionable improvements — no strings.
        </p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)">
          Review · Recommendations · Roadmap
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="#contact" class="btn-primary inline-flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">calendar_month</span>
        BOOK FREE AUDIT CALL
      </a>
    </div>
  </div>
</section>
