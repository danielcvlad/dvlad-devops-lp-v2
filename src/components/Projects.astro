---
import { resumeData } from '../data/resume';
---

<section class="py-24" style="background-color: var(--color-surface-container-low)" id="projects">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="flex flex-col items-center mb-16 gap-6">
      <h2 class="text-3xl font-bold headline-font tracking-tighter uppercase">Project Repository</h2>
      <div class="flex gap-4">
        <span class="text-xs font-mono flex items-center gap-2" style="color: var(--color-primary)">
          <span class="w-2 h-2" style="background-color: var(--color-primary)"></span> 12 DEPLOYED
        </span>
        <span class="text-xs font-mono flex items-center gap-2" style="color: var(--color-secondary)">
          <span class="w-2 h-2" style="background-color: var(--color-secondary)"></span> MORE IN_PROGRESS
        </span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {resumeData.projects.map(project => (
        <div class="project-card">
          <div class="flex justify-between items-start mb-6">
            <span class={`material-symbols-outlined text-3xl ${project.iconColor === 'primary' ? 'text-primary' : 'text-secondary'}`}>
              {project.icon}
            </span>
            <span class="text-[10px] font-mono uppercase tracking-tighter" style="color: var(--color-outline-variant)">Repo: {project.repo}</span>
          </div>

          <h3 class="text-lg font-bold headline-font mb-4" style={project.iconColor === 'primary' ? 'color: var(--color-primary)' : 'color: var(--color-secondary)'}>
            {project.title}
          </h3>

          <p class="text-sm mb-6 leading-relaxed" style="color: var(--color-on-surface-variant)">
            {project.description}
          </p>

          <div class="flex gap-2">
            {project.tags.map(tag => (
              <span class="text-[9px] font-mono px-2 py-0.5" style="background-color: var(--color-surface-container); color: var(--color-on-surface-variant)">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="https://github.com/danielcvlad?tab=repositories" target="_blank" class="btn-secondary inline-flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        VIEW_ALL_REPOS → GITHUB
      </a>
    </div>
  </div>
</section>
