---
const posts = [
  {
    title: "How I Cut Deployment Time by 70% with Azure DevOps",
    date: "2026-05-15",
    slug: "cut-deployment-time-azure-devops",
    tags: ["Azure", "CI/CD", "DevOps"],
    excerpt: "A real-world breakdown of pipeline optimization: parallel jobs, caching strategies, and the YAML patterns that made the difference."
  },
  {
    title: "Terraform vs Bicep: When to Use Which (and Why I Use Both)",
    date: "2026-05-01",
    slug: "terraform-vs-bicep",
    tags: ["Terraform", "Bicep", "IaC"],
    excerpt: "Both have their place in an Azure shop. Here's my decision framework after deploying both at scale."
  },
  {
    title: "Lessons from Deploying 500+ DevBox Environments",
    date: "2026-04-15",
    slug: "devbox-lessons",
    tags: ["Azure DevBox", "Infrastructure"],
    excerpt: "Scaling developer environments taught me more about IaC than any certification. The patterns, the pitfalls, and what I'd do differently."
  }
];
---

<section class="py-24" style="background-color: var(--color-background)" id="blog">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold headline-font tracking-tighter uppercase mb-4">Writing</h2>
      <p class="max-w-2xl mx-auto" style="color: var(--color-on-surface-variant)">
        Practical DevOps insights from the trenches. No fluff — just what actually works.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="project-card block no-underline group">
          <div class="flex gap-2 mb-4">
            {post.tags.map(tag => (
              <span class="text-[9px] font-mono px-2 py-0.5" style="background-color: var(--color-surface-container); color: var(--color-primary)">{tag}</span>
            ))}
          </div>
          <h3 class="text-lg font-bold headline-font mb-3 group-hover:underline" style="color: var(--color-on-surface)">
            {post.title}
          </h3>
          <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)">
            {post.excerpt}
          </p>
          <div class="text-[10px] font-mono" style="color: var(--color-outline-variant)">
            {post.date}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
