---
import { resumeData } from '../data/resume';

// Microsoft Learn certification badge URLs
const certBadges: Record<string, { bg: string; label: string }> = {
  expert: {
    bg: "https://learn.microsoft.com/media/learn/certification/badges/microsoft-certified-expert-badge.svg",
    label: "Expert"
  },
  associate: {
    bg: "https://learn.microsoft.com/media/learn/certification/badges/microsoft-certified-associate-badge.svg",
    label: "Associate"
  },
  specialty: {
    bg: "https://learn.microsoft.com/media/learn/certification/badges/microsoft-certified-specialty-badge.svg",
    label: "Specialty"
  }
};

// Microsoft Learn credential verification URLs (from CV PDF)
const verifyUrls: Record<string, string> = {
  "AZ-400": "https://learn.microsoft.com/api/credentials/share/en-us/DanielVlad-3730/1121D1CBC6B643BC?sharingId=1831A122A9A3BA9",
  "AZ-305": "https://learn.microsoft.com/api/credentials/share/en-us/DanielVlad-3730/36C8EF8009EDFAB9?sharingId=1831A122A9A3BA9",
  "AZ-500": "https://learn.microsoft.com/api/credentials/share/en-us/DanielVlad-3730/6F2E319C960F8316?sharingId=1831A122A9A3BA9",
  "AZ-104": "https://learn.microsoft.com/api/credentials/share/en-us/DanielVlad-3730/4DAD0DB97E5412CB?sharingId=1831A122A9A3BA9",
  "AZ-140": "https://learn.microsoft.com/api/credentials/share/en-us/DanielVlad-3730/6EB334077409C7D?sharingId=1831A122A9A3BA9",
};
---

<section class="py-24 max-w-6xl mx-auto px-6 text-center">
  <!-- JSON-LD Structured Data for Certifications -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Daniel Vlad",
    "url": "https://danielcvlad.github.io/dvlad-devops-lp/",
    "hasCredential": resumeData.certifications.map(cert => ({
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "certification",
      "name": cert.name,
      "identifier": cert.id,
      "issuer": {
        "@type": "Organization",
        "name": cert.issuer
      },
      "educationalLevel": cert.level
    }))
  })} />

  <h2 class="text-3xl font-bold headline-font tracking-tighter uppercase mb-16">Credentials</h2>

  <div class="max-w-3xl mx-auto border overflow-hidden" style="background-color: var(--color-surface-container-lowest); border-color: rgba(65, 71, 84, 0.2)">
    <!-- Terminal Header -->
    <div class="px-4 py-2 flex items-center justify-between" style="background-color: var(--color-surface-container-highest); border-bottom: 1px solid rgba(65, 71, 84, 0.2)">
      <span class="text-[10px] font-mono uppercase tracking-widest" style="color: var(--color-secondary); opacity: 0.7">
        Verified Credentials // Auth_Success
      </span>
      <div class="flex gap-1.5">
        <div class="w-2 h-2 rounded-full" style="background-color: var(--color-primary); opacity: 0.5"></div>
      </div>
    </div>

    <!-- Certifications List -->
    <div class="p-0 text-left">
      {resumeData.certifications.map((cert, index) => (
        <a
          href={verifyUrls[cert.id] || `https://learn.microsoft.com/api/credentials/verify/?authority=emeaDefaults&code=${cert.id}&verify=True`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center group no-underline transition-colors hover:no-underline"
          style={index === resumeData.certifications.length - 1 ? '' : 'border-bottom: 1px solid rgba(65, 71, 84, 0.1)'}
        >
          <div class="px-4 py-4 flex items-center justify-center shrink-0" style="border-right: 1px solid rgba(65, 71, 84, 0.1)">
            <div class="w-10 h-10 flex items-center justify-center">
              <img
                src={certBadges[cert.level.toLowerCase() as keyof typeof certBadges].bg}
                alt={`${cert.name} - ${cert.level} certification badge`}
                class="w-full h-full object-contain"
                loading="lazy"
              />
            </div>
          </div>
          <div class="px-5 py-4 flex-grow flex items-center justify-between gap-4">
            <div class="text-left">
              <div class="text-sm headline-font mb-0.5 tracking-tight" style="color: var(--color-on-surface)">
                {cert.name}
              </div>
              <div class="text-[10px] font-mono" style="color: var(--color-outline-variant)">
                {cert.id} · {cert.issuer} · {cert.level}
              </div>
            </div>
            <div class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity text-[9px] font-mono tracking-tight" style="color: var(--color-primary)">
              Verify ↗
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
